# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────
# Choose one by setting DB_ENGINE and uncommenting the matching block.
#
#   DB_ENGINE=sqlite       zero-config, no extra service needed
#   DB_ENGINE=postgresql   docker compose --profile postgres up
#   DB_ENGINE=mariadb      docker compose --profile mariadb up
#
DB_ENGINE=sqlite

# --- SQLite (default) ---
DB_NAME=/app/data/db.sqlite3

# --- PostgreSQL (profile: postgres) ---
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=pyapisim
# DB_USER=postgres
# DB_PASSWORD=change-me

# --- MariaDB / MySQL (profile: mariadb) ---
# DB_HOST=mariadb
# DB_PORT=3306
# DB_NAME=pyapisim
# DB_USER=pyapisim
# DB_PASSWORD=change-me
# DB_ROOT_PASSWORD=change-me-root
